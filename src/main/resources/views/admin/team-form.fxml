<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.TeamFormController">

    <Label fx:id="formTitle" text="Add Team"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="12">

        <Label text="Team Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" promptText="Enter team name" prefWidth="300"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Logo Path:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
            <TextField fx:id="logoField" promptText="logo-filename.png" prefWidth="220"/>
            <Button text="Browse..." onAction="#handleBrowse"/>
        </HBox>

        <Label text="Description:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextArea fx:id="descField" promptText="Describe the team..." prefWidth="300" prefHeight="80"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Captain ID:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="captainField" promptText="e.g. 1" prefWidth="300"
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>

        <Button text="Delete" fx:id="deleteBtn" onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>

        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>

</VBox>