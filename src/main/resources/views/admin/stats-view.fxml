<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="15" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.StatsController">

    <Label text="Stats Dashboard" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

    <!-- Export Button -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="exportExcelButton" text="📊 Export to Excel" onAction="#handleExportToExcel" 
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;">
            <tooltip>
                <Tooltip text="Export all statistics to Excel file"/>
            </tooltip>
        </Button>
        <Label fx:id="exportStatusLabel" text="" style="-fx-font-size: 12; -fx-text-fill: #27ae60;"/>
    </HBox>

    <!-- METRIC CARDS -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: #3498db; -fx-padding: 15; -fx-background-radius: 8;" prefWidth="180">
            <Label text="Total Games" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="totalGamesLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #2ecc71; -fx-padding: 15; -fx-background-radius: 8;" prefWidth="180">
            <Label text="Total Guides" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="totalGuidesLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #e74c3c; -fx-padding: 15; -fx-background-radius: 8;" prefWidth="180">
            <Label text="Total Ratings" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="totalRatingsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #f39c12; -fx-padding: 15; -fx-background-radius: 8;" prefWidth="180">
            <Label text="Avg Rating" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="avgRatingLabel" text="0.0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- USER STATISTICS CARDS -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: #9b59b6; -fx-padding: 15; -fx-background-radius: 8;" prefWidth="180">
            <Label text="Total Users" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="totalUsersLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </VBox>
        <VBox fx:id="bannedUsersCard" onMouseClicked="#handleShowBannedUsers" 
              style="-fx-background-color: #e67e22; -fx-padding: 15; -fx-background-radius: 8; -fx-cursor: hand;" prefWidth="180">
            <Label text="Banned Users" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="bannedUsersLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
            <Label text="👁️ Click to view" style="-fx-text-fill: white; -fx-font-size: 10; -fx-font-style: italic; -fx-padding: 5 0 0 0;"/>
        </VBox>
        <VBox style="-fx-background-color: #1abc9c; -fx-padding: 15; -fx-background-radius: 8;" prefWidth="180">
            <Label text="Active Users" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Label fx:id="activeUsersLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- CHARTS -->
    <HBox spacing="15">
        <!-- Bar Chart -->
        <BarChart fx:id="guidesPerGameChart" prefWidth="450" prefHeight="300">
            <xAxis><CategoryAxis label="Game"/></xAxis>
            <yAxis><NumberAxis label="Guides"/></yAxis>
        </BarChart>

        <!-- Pie Chart -->
        <PieChart fx:id="difficultyChart" prefWidth="300" prefHeight="300"
                  title="Difficulty Distribution"/>
    </HBox>

    <!-- LEADERBOARD -->
    <Label text="Top Rated Guides" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <TableView fx:id="leaderboardTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="colRank"    text="#"           prefWidth="50"/>
            <TableColumn fx:id="colTitle"   text="Guide"       prefWidth="250"/>
            <TableColumn fx:id="colGame"    text="Game"        prefWidth="150"/>
            <TableColumn fx:id="colAvgRating" text="Avg Rating" prefWidth="100"/>
            <TableColumn fx:id="colTotal"   text="Total Ratings" prefWidth="100"/>
        </columns>
    </TableView>

</VBox>