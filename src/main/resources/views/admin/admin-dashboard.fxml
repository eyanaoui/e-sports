<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esports.controllers.admin.AdminDashboardController"
            prefWidth="1100" prefHeight="650">

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 20; -fx-spacing: 10;" prefWidth="200">
            <Label text="⚡ Esports Admin"
                   style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-padding: 0 0 20 0;"/>
            <Button text="🎮  Games"      onAction="#showGames"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-alignment: CENTER-LEFT;"/>
            <Button text="📖  Guides"     onAction="#showGuides"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-alignment: CENTER-LEFT;"/>
            <Button text="🪜  Steps"      onAction="#showSteps"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-alignment: CENTER-LEFT;"/>
            <Button text="⭐  Ratings"    onAction="#showRatings"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-alignment: CENTER-LEFT;"/>
            <Separator style="-fx-background-color: #ffffff33;"/>
            <Button text="👤  User View"  onAction="#showUserView"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #aaaaaa; -fx-font-size: 14; -fx-alignment: CENTER-LEFT;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <AnchorPane fx:id="contentArea"/>
    </center>

</BorderPane>