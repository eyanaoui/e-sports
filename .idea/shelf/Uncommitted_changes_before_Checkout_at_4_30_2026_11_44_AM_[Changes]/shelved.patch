-package com.esports.utils;public class MiniGameService {
-}
+package com.esports.utils;
+
+import java.io.BufferedReader;
+import java.io.InputStreamReader;
+import java.net.HttpURLConnection;
+import java.net.URL;
+import java.net.URLEncoder;
+import java.nio.charset.StandardCharsets;
+
+public class MiniGameService {
+
+    public String generateMiniGameFromStep(String stepTitle, String stepContent) throws Exception {
+
+        String prompt = buildPrompt(stepTitle, stepContent);
+
+        String encodedPrompt = URLEncoder.encode(prompt, StandardCharsets.UTF_8);
+
+        String urlString = "https://text.pollinations.ai/" + encodedPrompt;
+
+        URL url = new URL(urlString);
+        HttpURLConnection connection = (HttpURLConnection) url.openConnection();
+
+        connection.setRequestMethod("GET");
+        connection.setConnectTimeout(20000);
+        connection.setReadTimeout(20000);
+
+        int responseCode = connection.getResponseCode();
+
+        if (responseCode != 200) {
+            throw new RuntimeException("LLM request failed with HTTP code: " + responseCode);
+        }
+
+        StringBuilder response = new StringBuilder();
+
+        try (BufferedReader reader = new BufferedReader(
+                new InputStreamReader(connection.getInputStream(), StandardCharsets.UTF_8))) {
+
+            String line;
+
+            while ((line = reader.readLine()) != null) {
+                response.append(line).append("\n");
+            }
+        }
+
+        String rawResponse = response.toString().trim();
+
+        System.out.println("=== RAW LLM RESPONSE START ===");
+        System.out.println(rawResponse);
+        System.out.println("=== RAW LLM RESPONSE END ===");
+
+        String cleanHtml = extractHtml(rawResponse);
+
+        if (!isValidHtml(cleanHtml)) {
+            throw new RuntimeException("Generated content is not valid playable HTML.");
+        }
+
+        return cleanHtml;
+    }
+
+    private String buildPrompt(String stepTitle, String stepContent) {
+        return """
+Create a VERY SIMPLE playable HTML5 canvas mini-game inspired by this guide step.
+
+STEP TITLE:
+%s
+
+STEP CONTENT:
+%s
+
+STRICT RULES:
+1. Return a complete HTML document.
+2. The game must be self-contained in one file.
+3. Use only HTML, CSS and vanilla JavaScript.
+4. Use a canvas of exactly 400x300 pixels.
+5. No external libraries, no images, no fonts, no API calls.
+6. Use only primitive graphics: circles, rectangles, text, simple colors.
+7. The game must start automatically on load.
+8. The game must display a score.
+9. The game must end after a short timer.
+10. Keep it very simple and lightweight.
+11. Match the game idea to the step text in a simple way.
+12. Good game types: clicking targets, reaction test, collecting objects, avoiding obstacles, timing challenge.
+13. Include <!DOCTYPE html>, <html>, <body>, <canvas>, and JavaScript.
+14. Do not make anything complex.
+"""
+                .formatted(
+                        safe(stepTitle),
+                        safe(stepContent)
+                );
+    }
+
+    private String safe(String text) {
+        if (text == null) {
+            return "";
+        }
+        return text.replace("\r", " ").replace("\n", " ").trim();
+    }
+
+    private String extractHtml(String raw) {
+        if (raw == null || raw.isBlank()) {
+            return "";
+        }
+
+        String cleaned = raw
+                .replace("```html", "")
+                .replace("```HTML", "")
+                .replace("```", "")
+                .trim();
+
+        int doctypeStart = cleaned.toLowerCase().indexOf("<!doctype html>");
+        int htmlStart = cleaned.toLowerCase().indexOf("<html");
+        int htmlEnd = cleaned.toLowerCase().lastIndexOf("</html>");
+
+        if (doctypeStart != -1 && htmlEnd != -1 && htmlEnd > doctypeStart) {
+            return cleaned.substring(doctypeStart, htmlEnd + "</html>".length()).trim();
+        }
+
+        if (htmlStart != -1 && htmlEnd != -1 && htmlEnd > htmlStart) {
+            String htmlBlock = cleaned.substring(htmlStart, htmlEnd + "</html>".length()).trim();
+
+            if (!htmlBlock.toLowerCase().startsWith("<!doctype html>")) {
+                htmlBlock = "<!DOCTYPE html>\n" + htmlBlock;
+            }
+
+            return htmlBlock;
+        }
+
+        return cleaned;
+    }
+
+    private boolean isValidHtml(String html) {
+        if (html == null || html.isBlank()) {
+            return false;
+        }
+
+        String lower = html.toLowerCase();
+
+        return lower.contains("<!doctype html>")
+                && lower.contains("<html")
+                && lower.contains("<body")
+                && lower.contains("<canvas")
+                && lower.contains("</html>");
+    }
+}
